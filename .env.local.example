# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจริง

# จาก Google Cloud Console > APIs & Services > Credentials (ดูขั้นตอนใน SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# รันคำสั่ง: openssl rand -base64 32
NEXTAUTH_SECRET=

# ตอน dev ใช้ http://localhost:3000 ตอน deploy ขึ้น Vercel ใช้ URL จริงของแอป
NEXTAUTH_URL=http://localhost:3000

# Spreadsheet ID จาก URL ของ Google Sheet ที่ import template ไปแล้ว
# ตัวอย่าง URL: https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXX/edit
# Spreadsheet ID คือส่วน XXXXXXXXXXXXXXXXXXXX
SHEET_ID=
